# Conexión a PostgreSQL (Prisma)
DATABASE_URL="postgresql://usuario:password@localhost:5432/broker_seguros?schema=public"

# Puerto HTTP de la API
PORT=3000

# Entorno: development | production | test
NODE_ENV=development

# Secreto para firmar los JWT (obligatorio). Generá uno fuerte en producción.
JWT_SECRET="cambiame-por-un-secreto-largo-y-aleatorio"

# Usuario ADMIN inicial (solo lo usa el seed para crearlo/upsertearlo).
ADMIN_EMAIL="admin@ejemplo.com"
ADMIN_PASSWORD="cambiame"
